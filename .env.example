NANOCLAW_PROJECT_ROOT=/absolute/path/to/your/nanoclaw/repo

OTEL_ENABLED=true
# OTLP base endpoint, or set trace/log endpoints separately below
# OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer your-token
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=authorization=Bearer your-token
# OTEL_EXPORTER_OTLP_LOGS_HEADERS=authorization=Bearer your-token
# DEPLOYMENT_ENVIRONMENT=development

LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=nanoclaw
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
# LANGSMITH_MAX_BODY_BYTES=262144
